services:
  app:
    build: .
    ports:
      - "${APP_PORT:-{{ app_port }}}:{{ app_port }}"
    env_file: .env
    {% set has_deps = has_postgres or has_mysql or has_redis or has_mongo %}
    {% if has_deps %}
    depends_on:
      {% if has_postgres %}
      postgres:
        condition: service_healthy
      {% endif %}
      {% if has_mysql %}
      mysql:
        condition: service_healthy
      {% endif %}
      {% if has_redis %}
      redis:
        condition: service_healthy
      {% endif %}
      {% if has_mongo %}
      mongo:
        condition: service_healthy
      {% endif %}
    {% endif %}
    networks:
      - app-network

  {% if has_postgres %}
  postgres:
    image: postgres:16-alpine
    environment:
      POSTGRES_USER:     ${DB_USER}
      POSTGRES_PASSWORD: ${DB_PASSWORD}
      POSTGRES_DB:       ${DB_NAME}
    ports:
      - "${DB_PORT:-5432}:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test:     ["CMD", "pg_isready", "-U", "${DB_USER}"]
      interval: 10s
      timeout:  5s
      retries:  5
    networks:
      - app-network
  {% endif %}

  {% if has_mysql %}
  mysql:
    image: mysql:8.0
    environment:
      MYSQL_USER:          ${DB_USER}
      MYSQL_PASSWORD:      ${DB_PASSWORD}
      MYSQL_DATABASE:      ${DB_NAME}
      MYSQL_ROOT_PASSWORD: ${DB_ROOT_PASSWORD}
    ports:
      - "${DB_PORT:-3306}:3306"
    volumes:
      - mysqldata:/var/lib/mysql
    healthcheck:
      test:     ["CMD", "mysqladmin", "ping", "-h", "localhost"]
      interval: 10s
      timeout:  5s
      retries:  5
    networks:
      - app-network
  {% endif %}

  {% if has_redis %}
  redis:
    image: redis:7-alpine
    ports:
      - "${REDIS_PORT:-6379}:6379"
    volumes:
      - redisdata:/data
    healthcheck:
      test:     ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout:  5s
      retries:  5
    networks:
      - app-network
  {% endif %}

  {% if has_nginx %}
  nginx:
    image: nginx:alpine
    ports:
      - "80:80"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
    depends_on:
      - app
    healthcheck:
      test:     ["CMD", "wget", "--quiet", "--tries=1", "--spider", "http://localhost/"]
      interval: 10s
      timeout:  5s
      retries:  3
    networks:
      - app-network
  {% endif %}

  {% if has_mongo %}
  mongo:
    image: mongo:7
    environment:
      MONGO_INITDB_ROOT_USERNAME: ${MONGO_USER}
      MONGO_INITDB_ROOT_PASSWORD: ${MONGO_PASSWORD}
    ports:
      - "${MONGO_PORT:-27017}:27017"
    volumes:
      - mongodata:/data/db
    healthcheck:
      test:     ["CMD", "mongosh", "--eval", "db.adminCommand('ping')"]
      interval: 10s
      timeout:  5s
      retries:  5
    networks:
      - app-network
  {% endif %}

volumes:
  {% if has_postgres %}
  pgdata:
  {% endif %}
  {% if has_mysql %}
  mysqldata:
  {% endif %}
  {% if has_redis %}
  redisdata:
  {% endif %}
  {% if has_mongo %}
  mongodata:
  {% endif %}

networks:
  app-network:
    driver: bridge
