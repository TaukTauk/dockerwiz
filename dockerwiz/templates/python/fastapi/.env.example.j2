# Application
APP_PORT={{ app_port }}

{% if has_postgres %}
# PostgreSQL
DB_HOST=postgres
DB_PORT={{ db_port }}
DB_USER={{ db_user }}
DB_PASSWORD={{ db_password }}
DB_NAME={{ db_name }}
{% endif %}
{% if has_mysql %}
# MySQL
DB_HOST=mysql
DB_PORT=3306
DB_USER={{ db_user }}
DB_PASSWORD={{ db_password }}
DB_ROOT_PASSWORD={{ db_password }}
DB_NAME={{ db_name }}
{% endif %}
{% if has_redis %}
# Redis
REDIS_HOST=redis
REDIS_PORT=6379
{% endif %}
{% if has_nginx %}
# Nginx
NGINX_PORT=80
{% endif %}
{% if has_mongo %}
# MongoDB
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_USER={{ db_user }}
MONGO_PASSWORD={{ db_password }}
{% endif %}
